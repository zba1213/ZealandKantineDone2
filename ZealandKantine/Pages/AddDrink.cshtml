@page
@model ZealandKantine.Pages.AddDrinkModel
@{
}
<h2>🥤 Tilføj Drikkevare</h2>

<form method="post">
    <div style="margin-bottom: 10px;">
        <label>Navn:</label><br>
        <input type="text" asp-for="Product.Name" required />
    </div>

    <div style="margin-bottom: 10px;">
        <label>Pris (kr):</label><br>
        <input type="number" step="0.01" asp-for="Product.Price" required />
    </div>

    <div style="margin-bottom: 10px;">
        <label>Antal:</label><br>
        <input type="number" asp-for="Product.Quantity" value="1" />
    </div>

    <button type="submit" class="btn btn-success">💾 Gem</button>
    <a href="/" class="btn btn-secondary">⬅️ Tilbage</a>
</form>

<style>
    .btn {
        padding: 8px 15px;
        text-decoration: none;
        color: white;
        border-radius: 5px;
        margin: 5px;
    }

    .btn-success {
        background: green;
    }

    .btn-secondary {
        background: gray;
    }

    input {
        padding: 8px;
        width: 200px;
        border: 1px solid #ddd;
        border-radius: 5px;
    }
</style>