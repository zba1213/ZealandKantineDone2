@page
@model ZealandKantine.Pages.CartModel
@{
}
<h2>🛒 Din Indkøbskurv</h2>
@if (Model.CartItems.Count == 0)
{
    <p>Din kurv er tom. <a href="/">Gå tilbage til menuen</a></p>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Produkt</th>
                <th>Pris</th>
                <th>Antal</th>
                <th>Total</th>
                <th>Handling</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.CartItems)
            {
                <tr>
                    <td>@item.Name @(item.IsDrink ? "🥤 (10% rabat)" : "🍕")</td>
                    <td>@item.Price kr</td>
                    <td>
                        <form method="post" asp-page-handler="UpdateQuantity" style="display: inline;">
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <input type="number" name="quantity" value="@item.Quantity" min="1" style="width: 60px;" />
                            <button type="submit" class="btn btn-primary" style="background: blue; padding: 2px 10px;">Opdater</button>
                        </form>
                    </td>
                    <td>@item.EffectiveTotalPrice.ToString("0.00") kr</td> <!-- BRUG EffectiveTotalPrice -->
                    <td>
                        <form method="post" asp-page-handler="RemoveFromCart" style="display: inline;">
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <button type="submit" class="btn btn-danger">Fjern</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <td colspan="3"><strong>Total:</strong></td>
                <td><strong>@Model.TotalPrice.ToString("0.00") kr</strong></td>
                <td>
                    <form method="post" asp-page-handler="ClearCart">
                        <button type="submit" class="btn btn-danger">Tøm kurv</button>
                    </form>
                </td>
            </tr>
        </tfoot>
    </table>

    <div>
        <a href="/" class="btn btn-primary">⬅️ Fortsæt med at handle</a>
        <a href="/Paysite" class="btn btn-success">💳 Gå til kassen</a>
    </div>
}

<style>
    .btn {
        padding: 8px 15px;
        text-decoration: none;
        color: white;
        border-radius: 5px;
        margin: 5px;
        border: none;
        cursor: pointer;
    }

    .btn-primary {
        background: blue;
    }

    .btn-success {
        background: green;
    }

    .btn-danger {
        background: red;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th, td {
        padding: 10px;
        text-align: left;
        border: 1px solid #ddd;
    }
</style>